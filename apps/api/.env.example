# Для локального Postgres (Homebrew): 127.0.0.1 + sslmode=disable снимают типичные P1010 на Mac
DATABASE_URL="postgresql://sharedbudget:sharedbudget@127.0.0.1:5432/sharedbudget?schema=public&sslmode=disable"

# Access JWT (обязательно задать в проде)
JWT_ACCESS_SECRET="change-me-to-a-long-random-string"
JWT_ACCESS_EXPIRES_SEC="900"
JWT_REFRESH_EXPIRES_DAYS="7"
